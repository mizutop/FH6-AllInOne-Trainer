<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FH6Mod.ViewModels.Pages"
             x:Class="FH6Mod.Views.Pages.DatabaseView"
             x:DataType="vm:DatabaseViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24" Spacing="12">

            <!-- Quick action -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                <Button Classes="primary" Padding="16,8" FontSize="13"
                        Content="Unlock Everything"
                        ToolTip.Tip="Free Cars + Install Flags + Autoshow + Clear NEW + Add All Cars"
                        IsEnabled="{Binding CanToggle}"
                        Command="{Binding UnlockEverythingCommand}" />
            </StackPanel>

            <!-- No game warning -->
            <Border IsVisible="{Binding !CanToggle}"
                    Padding="10,6" CornerRadius="6" BorderThickness="1"
                    Background="#1AFF5555" BorderBrush="#FF5555">
                <TextBlock Text="FH6 is not running — start the game first."
                           FontSize="12" Foreground="#FFB4B4" TextWrapping="Wrap" />
            </Border>

            <!-- Status -->
            <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="10,6" CornerRadius="6" BorderThickness="1"
                    Background="#1A3DDC97" BorderBrush="#3DDC97">
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
            </Border>

            <!-- Section: Toggle locks -->
            <TextBlock Text="PERSISTENT LOCKS (re-applied every 10s)" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDim}" Margin="0,6,0,0" />

            <!-- Free Cars -->
            <Grid ColumnDefinitions="180,*,Auto" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Free Cars (BaseCost=0)" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Classes="ghost" Content="Apply once" Padding="10,4" FontSize="11"
                            IsEnabled="{Binding CanToggle}"
                            Command="{Binding FreeCarPricesCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsFreeCarsLockOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleFreeCarsLockCommand}" />
            </Grid>

            <!-- Autoshow -->
            <Grid ColumnDefinitions="180,*,Auto" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Autoshow All Visible" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Classes="ghost" Content="Apply once" Padding="10,4" FontSize="11"
                            IsEnabled="{Binding CanToggle}"
                            Command="{Binding AutoshowUnlockCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsAutoshowLockOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleAutoshowLockCommand}" />
            </Grid>

            <!-- Install Flags -->
            <Grid ColumnDefinitions="180,*,Auto" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Install Flags" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Classes="ghost" Content="Apply once" Padding="10,4" FontSize="11"
                            IsEnabled="{Binding CanToggle}"
                            Command="{Binding InstallFlagsCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsInstallFlagsLockOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleInstallFlagsLockCommand}" />
            </Grid>

            <!-- Section: One-shot actions -->
            <TextBlock Text="ONE-SHOT ACTIONS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDim}" Margin="0,6,0,0" />

            <!-- Clear NEW Tag -->
            <Grid ColumnDefinitions="180,*" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Clear NEW! Tag" VerticalAlignment="Center" FontSize="13" />
                <Button Grid.Column="1" Classes="ghost" Content="Apply" Padding="10,4" FontSize="11"
                        HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                        Command="{Binding ClearNewTagCommand}" />
            </Grid>

            <!-- Add All Cars -->
            <Grid ColumnDefinitions="180,*" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Add All Cars (free grant)" VerticalAlignment="Center" FontSize="13" />
                <Button Grid.Column="1" Classes="ghost" Content="Apply" Padding="10,4" FontSize="11"
                        HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                        Command="{Binding AddAllCarsCommand}" />
            </Grid>

            <!-- Free Upgrades -->
            <Grid ColumnDefinitions="180,*" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Free Upgrades (47 tables)" VerticalAlignment="Center" FontSize="13" />
                <Button Grid.Column="1" Classes="ghost" Content="Apply" Padding="10,4" FontSize="11"
                        HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                        Command="{Binding FreeUpgradesCommand}" />
            </Grid>

            <!-- Free Wheels -->
            <Grid ColumnDefinitions="180,*" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Free Wheels" VerticalAlignment="Center" FontSize="13" />
                <Button Grid.Column="1" Classes="ghost" Content="Apply" Padding="10,4" FontSize="11"
                        HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                        Command="{Binding FreeWheelsCommand}" />
            </Grid>

            <!-- Unlock Upgrade Presets -->
            <Grid ColumnDefinitions="180,*" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Unlock Upgrade Presets" VerticalAlignment="Center" FontSize="13" />
                <Button Grid.Column="1" Classes="ghost" Content="Apply" Padding="10,4" FontSize="11"
                        HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                        Command="{Binding UnlockPresetsCommand}" />
            </Grid>

            <!-- Full Autoshow (CarBuckets) -->
            <Grid ColumnDefinitions="180,*" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Full Autoshow (CarBuckets)" VerticalAlignment="Center" FontSize="13" />
                <Button Grid.Column="1" Classes="ghost" Content="Apply" Padding="10,4" FontSize="11"
                        HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                        Command="{Binding FullAutoshowCommand}" />
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
