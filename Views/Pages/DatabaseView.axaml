<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FH6Mod.ViewModels.Pages"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="FH6Mod.Views.Pages.DatabaseView"
             x:DataType="vm:DatabaseViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16" Spacing="12">

            <!-- Hero: Unlock Everything -->
            <Border Classes="hero-card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding [Database.HeroTitle]}" Classes="h3" />
                    <TextBlock Text="{Binding [Database.HeroSubtitle]}"
                               Classes="subtle" TextWrapping="Wrap" />
                    <Button Classes="primary" Padding="16,8" Content="{Binding [Database.UnlockEverything]}"
                            ToolTip.Tip="{Binding [Database.UnlockEverythingTip]}"
                            IsEnabled="{Binding CanToggle}"
                            Command="{Binding UnlockEverythingCommand}" />
                </StackPanel>
            </Border>

            <!-- Status -->
            <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="10,6" CornerRadius="8" BorderThickness="1"
                    Background="#1A3DDC97" BorderBrush="#3DDC97">
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
            </Border>

            <!-- Persistent Locks card -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding [Database.PersistentLocks]}" Classes="section-header" />
                    <TextBlock Text="{Binding [Database.PersistentLocksHint]}" Classes="dim" Margin="0,-4,0,0" />

                    <!-- Free Cars -->
                    <Grid ColumnDefinitions="160,*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.FreeCars]}" VerticalAlignment="Center" FontSize="12" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <Button Classes="ghost-sm" Content="{Binding [Database.ApplyOnce]}"
                                    IsEnabled="{Binding CanToggle}"
                                    Command="{Binding FreeCarPricesCommand}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                                      IsChecked="{Binding IsFreeCarsLockOn, Mode=OneWay}"
                                      IsEnabled="{Binding CanToggle}"
                                      Command="{Binding ToggleFreeCarsLockCommand}" />
                    </Grid>

                    <!-- Autoshow -->
                    <Grid ColumnDefinitions="160,*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.Autoshow]}" VerticalAlignment="Center" FontSize="12" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <Button Classes="ghost-sm" Content="{Binding [Database.ApplyOnce]}"
                                    IsEnabled="{Binding CanToggle}"
                                    Command="{Binding AutoshowUnlockCommand}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                                      IsChecked="{Binding IsAutoshowLockOn, Mode=OneWay}"
                                      IsEnabled="{Binding CanToggle}"
                                      Command="{Binding ToggleAutoshowLockCommand}" />
                    </Grid>

                    <!-- Install Flags -->
                    <Grid ColumnDefinitions="160,*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.InstallFlags]}" VerticalAlignment="Center" FontSize="12" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <Button Classes="ghost-sm" Content="{Binding [Database.ApplyOnce]}"
                                    IsEnabled="{Binding CanToggle}"
                                    Command="{Binding InstallFlagsCommand}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                                      IsChecked="{Binding IsInstallFlagsLockOn, Mode=OneWay}"
                                      IsEnabled="{Binding CanToggle}"
                                      Command="{Binding ToggleInstallFlagsLockCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- One-Shot Actions card -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding [Database.OneShot]}" Classes="section-header" />

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.ClearNew]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                                Command="{Binding ClearNewTagCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.AddAllCars]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                                Command="{Binding AddAllCarsCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.FreeUpgrades]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                                Command="{Binding FreeUpgradesCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.FreeWheels]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                                Command="{Binding FreeWheelsCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.UpgradePresets]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                                Command="{Binding UnlockPresetsCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.FillCarBuckets]}"
                                   VerticalAlignment="Center" FontSize="12"
                                   ToolTip.Tip="{Binding [Database.FillCarBucketsTip]}" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                HorizontalAlignment="Left" IsEnabled="{Binding CanToggle}"
                                Command="{Binding FullAutoshowCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Season card with visual selectors -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding [Database.Season]}" Classes="section-header" />

                    <TextBlock Margin="0,-4,0,0">
                        <Run Text="{Binding [Database.SeasonCurrent]}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
                        <Run Text="{Binding CurrentSeasonText}" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentBrush}" />
                    </TextBlock>

                    <!-- Season selector cards -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <!-- Spring -->
                        <Button Padding="0" BorderThickness="0" Background="Transparent"
                                Command="{Binding SetSpringCommand}" IsEnabled="{Binding CanToggle}">
                            <Border Width="88" Height="56" CornerRadius="8"
                                    Background="{DynamicResource SeasonSpringBg}"
                                    BorderBrush="{DynamicResource SeasonSpring}" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                    <mi:MaterialIcon Kind="FlowerTulipOutline" Width="20" Height="20"
                                                     Foreground="{DynamicResource SeasonSpring}" />
                                    <TextBlock Text="{Binding [Database.SeasonSpring]}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SeasonSpring}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Summer -->
                        <Button Padding="0" BorderThickness="0" Background="Transparent"
                                Command="{Binding SetSummerCommand}" IsEnabled="{Binding CanToggle}">
                            <Border Width="88" Height="56" CornerRadius="8"
                                    Background="{DynamicResource SeasonSummerBg}"
                                    BorderBrush="{DynamicResource SeasonSummer}" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                    <mi:MaterialIcon Kind="WhiteBalanceSunny" Width="20" Height="20"
                                                     Foreground="{DynamicResource SeasonSummer}" />
                                    <TextBlock Text="{Binding [Database.SeasonSummer]}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SeasonSummer}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Autumn -->
                        <Button Padding="0" BorderThickness="0" Background="Transparent"
                                Command="{Binding SetAutumnCommand}" IsEnabled="{Binding CanToggle}">
                            <Border Width="88" Height="56" CornerRadius="8"
                                    Background="{DynamicResource SeasonAutumnBg}"
                                    BorderBrush="{DynamicResource SeasonAutumn}" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                    <mi:MaterialIcon Kind="Leaf" Width="20" Height="20"
                                                     Foreground="{DynamicResource SeasonAutumn}" />
                                    <TextBlock Text="{Binding [Database.SeasonAutumn]}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SeasonAutumn}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Winter -->
                        <Button Padding="0" BorderThickness="0" Background="Transparent"
                                Command="{Binding SetWinterCommand}" IsEnabled="{Binding CanToggle}">
                            <Border Width="88" Height="56" CornerRadius="8"
                                    Background="{DynamicResource SeasonWinterBg}"
                                    BorderBrush="{DynamicResource SeasonWinter}" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                    <mi:MaterialIcon Kind="Snowflake" Width="20" Height="20"
                                                     Foreground="{DynamicResource SeasonWinter}" />
                                    <TextBlock Text="{Binding [Database.SeasonWinter]}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SeasonWinter}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>

                    <TextBlock Classes="dim" Text="{Binding [Database.SeasonHint]}" />
                </StackPanel>
            </Border>

            <!-- Physics & Performance card -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding [Database.Physics]}" Classes="section-header" />

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.DriftScore10x]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                ToolTip.Tip="{Binding [Database.DriftScore10xTip]}"
                                IsEnabled="{Binding CanToggle}"
                                Command="{Binding DriftScoreCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.MaxTraction]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                ToolTip.Tip="{Binding [Database.MaxTractionTip]}"
                                IsEnabled="{Binding CanToggle}"
                                Command="{Binding MaxTractionCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.TorqueScale]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                ToolTip.Tip="{Binding [Database.TorqueScaleTip]}"
                                IsEnabled="{Binding CanToggle}"
                                Command="{Binding TorqueScaleCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="160,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Database.ReduceDrag]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Classes="ghost-sm" Content="{Binding [Database.Apply]}"
                                ToolTip.Tip="{Binding [Database.ReduceDragTip]}"
                                IsEnabled="{Binding CanToggle}"
                                Command="{Binding DragScaleCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
