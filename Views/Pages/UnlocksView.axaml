<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="using:FH6Mod.ViewModels.Pages"
             xmlns:b="using:FH6Mod.Behaviors"
             x:Class="FH6Mod.Views.Pages.UnlocksView"
             x:DataType="vm:UnlocksViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="36,28" Spacing="20" b:StaggerEntrance.Enable="True">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="14">
                <Border Background="{DynamicResource Surface2Brush}"
                        BorderBrush="{DynamicResource SurfaceBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="10">
                    <materialIcons:MaterialIcon Kind="{Binding PageIcon}" Width="22" Height="22"
                                                Foreground="{DynamicResource AccentBrush}" />
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding PageTitle}" Classes="h1" />
                    <TextBlock Text="{Binding PageSubtitle}" Classes="subtle" />
                </StackPanel>
            </StackPanel>

            <!-- Status -->
            <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" CornerRadius="8" BorderThickness="1"
                    Background="#1A3DDC97" BorderBrush="#3DDC97">
                <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
            </Border>

            <Border IsVisible="{Binding DiagnosticsMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" CornerRadius="8" BorderThickness="1"
                    Background="{DynamicResource Surface1Brush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="ENGINE LOG" Classes="eyebrow" />
                    <TextBlock Text="{Binding DiagnosticsMessage}" FontSize="11"
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Behaviour note -->
            <Border Padding="14,10" CornerRadius="8" BorderThickness="1"
                    Background="#1A4DA3FF" BorderBrush="#4DA3FF">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="#7FBFFF"
                               Text="ℹ  How runtime hooks work" />
                    <TextBlock FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"
                               Text="Hooks override game values when the game recalculates them. The new value kicks in on the next game event (finishing a race, ending a skill chain, selling a car, etc.). Toggle stays armed — just keep playing." />
                </StackPanel>
            </Border>

            <!-- ===== MAX ALL ===== -->
            <Border Padding="22" CornerRadius="12" BorderThickness="2"
                    Background="#2AFF6A1F" BorderBrush="{DynamicResource AccentBrush}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="18">
                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="12" Background="#3AFF6A1F">
                        <materialIcons:MaterialIcon Kind="RocketLaunchOutline" Width="26" Height="26"
                            Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Max All" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="Set Credits to 999M, Wheelspins to 999, Super Wheelspins to 999, Skill Points to 999K — all at once." Classes="dim" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="2" Classes="primary" FontSize="14" Padding="20,10"
                            Content="MAX ALL" Command="{Binding MaxAllCommand}" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <TextBlock Text="RUNTIME HOOKS — WORKING" Classes="eyebrow" />

            <!-- Credits -->
            <Border Classes="card" Padding="22">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="CashMultiple" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Credits" Classes="h3" />
                            <TextBlock Text="Lock credits at custom value." Classes="dim" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsCreditsOn, Mode=OneWay}"
                                      Command="{Binding ToggleCreditsCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding CreditsAmountText}" />
                        <Button Grid.Column="1" Classes="ghost" Content="10K" Command="{Binding SetCreditsCommand}" CommandParameter="10000" />
                        <Button Grid.Column="2" Classes="ghost" Content="100K" Command="{Binding SetCreditsCommand}" CommandParameter="100000" />
                        <Button Grid.Column="3" Classes="ghost" Content="1M" Command="{Binding SetCreditsCommand}" CommandParameter="1000000" />
                        <Button Grid.Column="4" Classes="ghost" Content="100M" Command="{Binding SetCreditsCommand}" CommandParameter="100000000" />
                        <Button Grid.Column="5" Classes="ghost" Content="999M" Command="{Binding SetCreditsCommand}" CommandParameter="999999999" />
                        <Button Grid.Column="6" Classes="primary" Content="Apply" Command="{Binding ApplyCreditsCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Wheelspins -->
            <Border Classes="card" Padding="22">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="SlotMachineOutline" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Wheelspins" Classes="h3" />
                            <TextBlock Text="Set wheelspin count." Classes="dim" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsWheelspinsOn, Mode=OneWay}"
                                      Command="{Binding ToggleWheelspinsCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding WheelspinsAmountText}" />
                        <Button Grid.Column="1" Classes="ghost" Content="10" Command="{Binding SetWheelspinsCommand}" CommandParameter="10" />
                        <Button Grid.Column="2" Classes="ghost" Content="50" Command="{Binding SetWheelspinsCommand}" CommandParameter="50" />
                        <Button Grid.Column="3" Classes="ghost" Content="100" Command="{Binding SetWheelspinsCommand}" CommandParameter="100" />
                        <Button Grid.Column="4" Classes="ghost" Content="999" Command="{Binding SetWheelspinsCommand}" CommandParameter="999" />
                        <Button Grid.Column="5" Classes="primary" Content="Apply" Command="{Binding ApplyWheelspinsCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Super Wheelspins -->
            <Border Classes="card" Padding="22">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="StarFourPointsOutline" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Super Wheelspins" Classes="h3" />
                            <TextBlock Text="Set super wheelspin count." Classes="dim" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsSuperWheelspinsOn, Mode=OneWay}"
                                      Command="{Binding ToggleSuperWheelspinsCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding SuperWheelspinsAmountText}" />
                        <Button Grid.Column="1" Classes="ghost" Content="10" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="10" />
                        <Button Grid.Column="2" Classes="ghost" Content="50" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="50" />
                        <Button Grid.Column="3" Classes="ghost" Content="100" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="100" />
                        <Button Grid.Column="4" Classes="ghost" Content="999" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="999" />
                        <Button Grid.Column="5" Classes="primary" Content="Apply" Command="{Binding ApplySuperWheelspinsCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Skill Points -->
            <Border Classes="card" Padding="22">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="Star" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Skill Points" Classes="h3" />
                            <TextBlock Text="Lock skill points at custom value." Classes="dim" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsSkillPointsOn, Mode=OneWay}"
                                      Command="{Binding ToggleSkillPointsCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding SkillPointsAmountText}" />
                        <Button Grid.Column="1" Classes="ghost" Content="100" Command="{Binding SetSkillPointsCommand}" CommandParameter="100" />
                        <Button Grid.Column="2" Classes="ghost" Content="1K" Command="{Binding SetSkillPointsCommand}" CommandParameter="1000" />
                        <Button Grid.Column="3" Classes="ghost" Content="10K" Command="{Binding SetSkillPointsCommand}" CommandParameter="10000" />
                        <Button Grid.Column="4" Classes="ghost" Content="999K" Command="{Binding SetSkillPointsCommand}" CommandParameter="999999" />
                        <Button Grid.Column="5" Classes="primary" Content="Apply" Command="{Binding ApplySkillPointsCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Sell Payout -->
            <Border Classes="card" Padding="22">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="CashRefund" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Sell Payout x" Classes="h3" />
                            <TextBlock Text="Multiply car sell price by N." Classes="dim" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsSellPayoutOn, Mode=OneWay}"
                                      Command="{Binding ToggleSellPayoutCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding SellPayoutText}" />
                        <Button Grid.Column="1" Classes="primary" Content="Apply" Command="{Binding ApplySellPayoutCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== BROKEN ===== -->
            <TextBlock Text="BROKEN — patched by game update" Classes="eyebrow" Margin="0,10,0,0" />

            <Border Classes="card broken" Padding="22" IsEnabled="False">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="ChartBellCurve" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Drift Score Multiplier" Classes="h3" />
                                <Border Classes="brokenPill"><TextBlock Text="BROKEN" /></Border>
                            </StackPanel>
                            <TextBlock Text="Game-patched signature." Classes="dim" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" IsChecked="False" IsEnabled="False" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card broken" Padding="22" IsEnabled="False">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                        <materialIcons:MaterialIcon Kind="ShieldOff" Width="22" Height="22"
                            Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="No Skill Break" Classes="h3" />
                            <Border Classes="brokenPill"><TextBlock Text="BROKEN" /></Border>
                        </StackPanel>
                        <TextBlock Text="Game-patched signature." Classes="dim" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="2" IsChecked="False" IsEnabled="False" />
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
