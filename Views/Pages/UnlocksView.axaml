<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FH6Mod.ViewModels.Pages"
             x:Class="FH6Mod.Views.Pages.UnlocksView"
             x:DataType="vm:UnlocksViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24" Spacing="8">

            <!-- Quick actions -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                <Button Classes="primary" Padding="16,8" FontSize="13"
                        Content="Quick Start"
                        ToolTip.Tip="999M Credits + Free Cars + Autoshow Unlock + All Cars"
                        IsEnabled="{Binding CanToggle}"
                        Command="{Binding QuickStartCommand}" />
                <Button Classes="primary" Padding="16,8" FontSize="13"
                        Content="Max All"
                        ToolTip.Tip="Max Credits, Wheelspins, Super Wheelspins, Skill Points"
                        IsEnabled="{Binding CanToggle}"
                        Command="{Binding MaxAllCommand}" />
            </StackPanel>

            <!-- No game warning -->
            <Border IsVisible="{Binding !CanToggle}"
                    Padding="10,6" CornerRadius="6" BorderThickness="1"
                    Background="#1AFF5555" BorderBrush="#FF5555">
                <TextBlock Text="FH6 is not running — start the game first, then cheats will unlock."
                           FontSize="12" Foreground="#FFB4B4" TextWrapping="Wrap" />
            </Border>

            <!-- Status -->
            <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="10,6" CornerRadius="6" BorderThickness="1"
                    Background="#1A3DDC97" BorderBrush="#3DDC97">
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
            </Border>

            <!-- ========== PROFILE VALUES ========== -->
            <TextBlock Text="PROFILE VALUES" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDim}" Margin="0,8,0,0" />

            <!-- Credits -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Credits (CR)" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding CreditsAmountText}" Width="100" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="10K" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="10000" />
                    <Button Classes="ghost" Content="100K" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="100000" />
                    <Button Classes="ghost" Content="1M" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="1000000" />
                    <Button Classes="ghost" Content="100M" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="100000000" />
                    <Button Classes="ghost" Content="999M" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="999999999" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplyCreditsCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsCreditsOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleCreditsCommand}" />
            </Grid>

            <!-- Wheelspins -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Wheelspins" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding WheelspinsAmountText}" Width="70" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="10" Padding="6,4" FontSize="11" Command="{Binding SetWheelspinsCommand}" CommandParameter="10" />
                    <Button Classes="ghost" Content="50" Padding="6,4" FontSize="11" Command="{Binding SetWheelspinsCommand}" CommandParameter="50" />
                    <Button Classes="ghost" Content="100" Padding="6,4" FontSize="11" Command="{Binding SetWheelspinsCommand}" CommandParameter="100" />
                    <Button Classes="ghost" Content="999" Padding="6,4" FontSize="11" Command="{Binding SetWheelspinsCommand}" CommandParameter="999" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplyWheelspinsCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsWheelspinsOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleWheelspinsCommand}" />
            </Grid>

            <!-- Super Wheelspins -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Super Wheelspins" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding SuperWheelspinsAmountText}" Width="70" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="10" Padding="6,4" FontSize="11" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="10" />
                    <Button Classes="ghost" Content="50" Padding="6,4" FontSize="11" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="50" />
                    <Button Classes="ghost" Content="100" Padding="6,4" FontSize="11" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="100" />
                    <Button Classes="ghost" Content="999" Padding="6,4" FontSize="11" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="999" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplySuperWheelspinsCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsSuperWheelspinsOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleSuperWheelspinsCommand}" />
            </Grid>

            <!-- Skill Points -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Skill Points" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding SkillPointsAmountText}" Width="90" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="100" Padding="6,4" FontSize="11" Command="{Binding SetSkillPointsCommand}" CommandParameter="100" />
                    <Button Classes="ghost" Content="1K" Padding="6,4" FontSize="11" Command="{Binding SetSkillPointsCommand}" CommandParameter="1000" />
                    <Button Classes="ghost" Content="10K" Padding="6,4" FontSize="11" Command="{Binding SetSkillPointsCommand}" CommandParameter="10000" />
                    <Button Classes="ghost" Content="999K" Padding="6,4" FontSize="11" Command="{Binding SetSkillPointsCommand}" CommandParameter="999999" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplySkillPointsCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsSkillPointsOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleSkillPointsCommand}" />
            </Grid>

            <!-- Sell Payout -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Sell Payout x" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding SellPayoutText}" Width="60" VerticalAlignment="Center" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplySellPayoutCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsSellPayoutOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleSellPayoutCommand}" />
            </Grid>

            <!-- ========== DRIFT & SKILLS (working) ========== -->
            <TextBlock Text="DRIFT &amp; SKILLS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDim}" Margin="0,8,0,0" />

            <!-- Drift Score Multiplier -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Drift Score x" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding DriftMultiText}" Width="60" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="5" Padding="6,4" FontSize="11" Command="{Binding ApplyDriftMultiCommand}" />
                    <Button Classes="ghost" Content="10" Padding="6,4" FontSize="11" Command="{Binding ApplyDriftMultiCommand}" />
                    <Button Classes="ghost" Content="50" Padding="6,4" FontSize="11" Command="{Binding ApplyDriftMultiCommand}" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplyDriftMultiCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsDriftMultiOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleDriftMultiCommand}" />
            </Grid>

            <!-- No Skill Break -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="No Skill Break" VerticalAlignment="Center" FontSize="13" />
                <TextBlock Grid.Column="1" Text="Prevent skill chain from breaking on impacts" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextDim}" />
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsNoSkillBreakOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleNoSkillBreakCommand}" />
            </Grid>

            <!-- ========== NOT WORKING — needs reverse engineering ========== -->
            <TextBlock Text="NOT WORKING — NEEDS REVERSE ENGINEERING" FontSize="11" FontWeight="SemiBold"
                       Foreground="#FF5555" Margin="0,12,0,0" />
            <TextBlock Text="ForzaMods AIO signatures match wrong functions in current FH6 build. Toggling will show the reason."
                       FontSize="11" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap" Margin="0,0,0,4" />

            <!-- Freeze AI — confirmed wrong function -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Freeze AI Cars" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Hooks ratio calculator, not AI velocity" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF5555" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- No Clip — confirmed wrong function -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="No Clip" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Hooks string/hash compare, not collision" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF5555" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Teleport -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Teleport" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Gravity Multiplier -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Gravity x" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- No Water Drag -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="No Water Drag" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Remove Build Cap -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Remove Build Cap" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Time of Day -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Time of Day" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Skill Score Multiplier -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Skill Score x" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Prize Scale -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Prize Scale x" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Race Time Scale -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Race Time Scale" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Acceleration -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Acceleration" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Speed Trap Multiplier -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Speed Trap x" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Mission Time Scale -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Mission Time" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Free Clothing -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Free Clothing" VerticalAlignment="Center" FontSize="13"
                           TextDecorations="Strikethrough" />
                <TextBlock Grid.Column="1" Text="Unverified ForzaMods signature" VerticalAlignment="Center"
                           FontSize="11" Foreground="#FF8844" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Engine log -->
            <Border IsVisible="{Binding DiagnosticsMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="10,6" CornerRadius="6" BorderThickness="1"
                    Background="{DynamicResource Surface1Brush}" BorderBrush="{DynamicResource SurfaceBorderBrush}">
                <StackPanel Spacing="4">
                    <TextBlock Text="ENGINE LOG" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextDim}" />
                    <TextBlock Text="{Binding DiagnosticsMessage}" FontSize="11"
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
