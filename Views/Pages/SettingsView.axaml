<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FH6Mod.ViewModels.Pages"
             x:Class="FH6Mod.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16" Spacing="12">

            <!-- Preferences card -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding [Settings.Preferences]}" Classes="section-header" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Settings.Animations]}" VerticalAlignment="Center" FontSize="12" />
                        <ToggleSwitch Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding AnimationsEnabled, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Settings.MouseGlow]}" VerticalAlignment="Center" FontSize="12" />
                        <ToggleSwitch Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding MouseGlowEnabled, Mode=TwoWay}" />
                    </Grid>

                    <!-- Accent color -->
                    <StackPanel Spacing="6" Margin="0,4,0,0">
                        <TextBlock Text="{Binding [Settings.AccentColor]}" FontSize="12" />
                        <ItemsControl ItemsSource="{Binding AccentOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AccentItemVm">
                                    <Button Background="Transparent" BorderThickness="0" Padding="0"
                                            Margin="0,0,8,8" Cursor="Hand"
                                            ToolTip.Tip="{Binding Name}"
                                            Click="OnAccentSwatchClick">
                                        <Border Classes="accentSwatch"
                                                Classes.selected="{Binding IsSelected}"
                                                Width="28" Height="28" CornerRadius="999"
                                                BorderThickness="2" Padding="3">
                                            <Border CornerRadius="999"
                                                    Background="{Binding Base, Converter={StaticResource HexToBrushConverter}}" />
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Language -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,2,0,0">
                        <TextBlock Grid.Column="0" Text="{Binding [Settings.Language]}" VerticalAlignment="Center" FontSize="12" />
                        <ComboBox Grid.Column="1" HorizontalAlignment="Right" MinWidth="140"
                                  ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguageItem, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LanguageItemVm">
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Diagnostics card -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding [Settings.Diagnostics]}" Classes="section-header" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Settings.ScanSignatures]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Content="{Binding [Settings.ScanAll]}" Classes="primary" Padding="12,4" FontSize="11"
                                IsEnabled="{Binding !IsScanning}"
                                Command="{Binding ScanSignaturesCommand}" />
                    </Grid>
                    <TextBox Text="{Binding ScanStatus}" IsReadOnly="True"
                             FontFamily="Consolas, Courier New, monospace" FontSize="10"
                             TextWrapping="Wrap" IsVisible="{Binding ScanStatus, Converter={StaticResource NotNullConverter}}"
                             MaxHeight="180" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding [Settings.ConflictCheck]}" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Content="{Binding [Settings.Detect]}" Classes="primary" Padding="12,4" FontSize="11"
                                Command="{Binding DetectConflictsCommand}" />
                    </Grid>
                    <Border IsVisible="{Binding HasConflicts}" Background="#33FF4444" CornerRadius="6" Padding="8,4">
                        <TextBlock Text="{Binding ConflictStatus}" TextWrapping="Wrap"
                                   Foreground="#FF6666" FontFamily="Consolas, Courier New, monospace" FontSize="10" />
                    </Border>
                    <Border IsVisible="{Binding ConflictStatus, Converter={StaticResource NotNullConverter}}"
                            Background="{DynamicResource Surface2Brush}" CornerRadius="6" Padding="8,4">
                        <TextBlock Text="{Binding ConflictStatus}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontFamily="Consolas, Courier New, monospace" FontSize="10" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Profiles card -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding [Settings.Profiles]}" Classes="section-header" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" PlaceholderText="{Binding [Settings.ProfileNamePlaceholder]}"
                                 Text="{Binding ProfileName, Mode=TwoWay}" />
                        <Button Grid.Column="1" Content="{Binding [Settings.Save]}" Classes="primary" Padding="12,4" FontSize="11"
                                Command="{Binding SaveProfileCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <ComboBox Grid.Column="0" ItemsSource="{Binding SavedProfiles}"
                                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                  PlaceholderText="{Binding [Settings.SavedProfilesPlaceholder]}" />
                        <Button Grid.Column="1" Content="{Binding [Settings.Load]}" Classes="ghost" Padding="10,4" FontSize="11"
                                Command="{Binding LoadProfileCommand}" />
                        <Button Grid.Column="2" Content="{Binding [Settings.Delete]}" Classes="ghost" Padding="10,4" FontSize="11"
                                Command="{Binding DeleteProfileCommand}" />
                    </Grid>
                    <Button Content="{Binding [Settings.OpenProfilesFolder]}" Classes="ghost-sm" Padding="10,4"
                            HorizontalAlignment="Left"
                            Command="{Binding OpenProfilesFolderCommand}" />
                    <TextBlock Text="{Binding ProfileStatus}" Classes="dim" TextWrapping="Wrap"
                               IsVisible="{Binding ProfileStatus, Converter={StaticResource NotNullConverter}}" />
                </StackPanel>
            </Border>

            <!-- About card -->
            <Border Classes="card">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding [Settings.About]}" Classes="section-header" />
                    <TextBlock Classes="dim" TextWrapping="Wrap">
                        <Run Text="{Binding [Settings.AboutLine1]}" />
                        <Run Text=" · " />
                        <Run Text="{Binding VersionText}" />
                        <Run Text="{Binding [Settings.AboutLine2]}" />
                    </TextBlock>
                    <TextBlock Classes="dim" TextWrapping="Wrap" Text="{Binding [Settings.CreditsLine]}" />
                    <Button Content="{Binding [Settings.OpenSettingsFolder]}" Classes="ghost-sm"
                            HorizontalAlignment="Left" Margin="0,4,0,0"
                            Command="{Binding OpenSettingsFolderCommand}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
