<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FH6Mod.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="880" d:DesignHeight="620"
        Width="880" Height="620"
        MinWidth="720" MinHeight="500"
        x:Class="FH6Mod.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="FH6 All-in-One Trainer"
        Background="{DynamicResource Surface0Brush}"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/logo.png">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Title bar -->
        <Border Grid.Row="0" Padding="16,8"
                Background="{DynamicResource Surface0Brush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="FH6 Trainer" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentVersionText}" Classes="dim" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="{DynamicResource StatusErr}"
                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding GameStatusText}" Classes="subtle" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource Surface1Brush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <Button Classes="tab" Content="Cheats"
                        IsEnabled="{Binding SelectedTab, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=0}"
                        Command="{Binding SelectTabCommand}" CommandParameter="0" />
                <Button Classes="tab" Content="Database"
                        IsEnabled="{Binding SelectedTab, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=1}"
                        Command="{Binding SelectTabCommand}" CommandParameter="1" />
                <Button Classes="tab" Content="Settings"
                        IsEnabled="{Binding SelectedTab, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=2}"
                        Command="{Binding SelectTabCommand}" CommandParameter="2" />
            </StackPanel>
        </Border>

        <!-- Page content -->
        <ContentControl Grid.Row="2" Content="{Binding CurrentPage}" />
    </Grid>
</Window>
