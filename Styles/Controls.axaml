<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window chrome -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
        <Setter Property="FontFamily" Value="Inter, $Default" />
        <Setter Property="TransparencyLevelHint" Value="None" />
    </Style>

    <!-- Default text -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily" Value="Inter, $Default" />
    </Style>

    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LetterSpacing" Value="-0.5" />
    </Style>

    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="-0.3" />
    </Style>

    <Style Selector="TextBlock.h3">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.subtle">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="TextBlock.dim">
        <Setter Property="Foreground" Value="{DynamicResource TextDim}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="TextBlock.eyebrow">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="2" />
    </Style>

    <!-- Card container — flat, no hover lift -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Primary action button -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrushHover}" />
    </Style>

    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrushPressed}" />
    </Style>

    <!-- Ghost button -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrushMuted}" />
    </Style>

    <!-- Toggle switch tweaks -->
    <Style Selector="ToggleSwitch">
        <Setter Property="OnContent" Value="" />
        <Setter Property="OffContent" Value="" />
    </Style>

    <!-- Accent palette swatch -->
    <Style Selector="Border.accentSwatch">
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="Border.accentSwatch.selected">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
</Styles>
